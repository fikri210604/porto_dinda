---
import Layout from '../layouts/Layout.astro';
import Navbar from '../layouts/Navbar.jsx';
import Hero from '../components/Hero.jsx';
import About from '../components/About.jsx';
import Projects from '../components/Projects.jsx';
import Skills from '../components/Skills.jsx';
import ArtGallery from '../components/ArtGallery.jsx';
import Footer from '../layouts/Footer.jsx';
---

<Layout>
  <!-- Floating Glassmorphic Navbar -->
  <Navbar client:load />

  <main id="main-content">
    <!-- Hero: PORTFOLIO large text + photo assembly animation -->
    <Hero client:load />

    <!-- About Me + Software Skills Grid -->
    <About client:load />

    <!-- Architectural Projects Showcase (4 cards with 3D tilt) -->
    <Projects client:load />

    <!-- Graphic Design Gallery + Skills Marquee Ticker + Experiences Timeline -->
    <Skills client:load />

    <!-- Bento Grid Art Gallery -->
    <ArtGallery client:load />
  </main>

  <!-- Footer CTA -->
  <Footer client:load />
</Layout>
